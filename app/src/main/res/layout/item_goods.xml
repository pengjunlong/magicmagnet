<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="?android:attr/selectableItemBackground"
    android:layout_width="match_parent"
    android:layout_height="120dp"
    android:layout_margin="4dp">
    <com.othershe.library.NiceImageView
        android:id="@+id/iv_goods"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:scaleType="fitCenter"
        android:layout_weight="0.4"
        app:corner_radius="5dp"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_margin="4dp"
        android:layout_weight="1">
        <androidx.appcompat.widget.AppCompatTextView
            android:textStyle="bold"
            android:textColor="@color/default_font"
            android:ellipsize="end"
            android:id="@+id/tv_goods_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            android:maxLines="2"
            android:lineSpacingExtra="4sp"/>
        <TextView
            android:textColor="@android:color/white"
            android:background="@drawable/bg_coupon"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"/>
        <RelativeLayout
            android:padding="4dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="2dp">
            <ImageView
                android:id="@+id/iv_after_coupon"
                android:layout_width="40dp"
                android:layout_height="18dp"
                android:layout_margin="2dp"
                android:src="@drawable/ic_after_coupon"
                android:scaleType="fitCenter"
                android:layout_alignParentBottom="true"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/subtitle"
                android:id="@+id/tv_origin_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:layout_above="@+id/iv_after_coupon"/>
            <TextView
                android:textColor="@android:color/holo_red_dark"
                android:id="@+id/tv_after_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:layout_alignParentBottom="true"
                android:layout_toEndOf="@+id/iv_after_coupon"/>
            <TextView
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:id="@+id/tv_take_coupon"
                android:background="@drawable/bg_coupon"
                android:padding="4dp"
                android:paddingTop="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_alignParentBottom="true"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
    </LinearLayout>
</LinearLayout>
