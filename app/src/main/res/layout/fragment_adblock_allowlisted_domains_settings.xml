<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="@dimen/fragment_adblock_al_padding"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <EditText
            android:textAppearance="?android:attr/textAppearanceMedium"
            android:id="@+id/fragment_adblock_wl_add_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="@string/fragment_adblock_settings_add_domain"
            android:lines="1"
            android:layout_weight="1"
            android:inputType="textUri"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/fragment_adblock_wl_add_button"
            android:paddingLeft="@dimen/fragment_adblock_al_item_padding"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/fragment_adblock_allowlisted_domains_add"
            android:paddingStart="@dimen/fragment_adblock_al_item_padding"/>
    </LinearLayout>
    <TextView
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:paddingTop="@dimen/fragment_adblock_al_padding"
        android:paddingBottom="@dimen/fragment_adblock_al_padding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/fragment_adblock_settings_wl_domains"/>
    <ListView
        android:id="@+id/fragment_adblock_wl_listview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</LinearLayout>
