<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/container_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/layoutAppbar"
        android:fitsSystemWindows="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.appcompat.widget.Toolbar
            android:theme="@style/ToolbarIconColor"
            android:id="@+id/toolbar"
            android:fitsSystemWindows="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_collapseMode="pin"
            app:title="反馈"
            style="@style/ToolbarStyle"/>
    </com.google.android.material.appbar.AppBarLayout>
    <EditText
        android:gravity="top"
        android:id="@+id/edt_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="请详细写下你的问题或建议，以便为你提供更好的帮助"
        android:lines="5"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layoutAppbar"/>
    <EditText
        android:id="@+id/edt_contact"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:hint="（选填）联系方式"
        app:layout_constraintEnd_toEndOf="@+id/edt_content"
        app:layout_constraintStart_toStartOf="@+id/edt_content"
        app:layout_constraintTop_toBottomOf="@+id/edt_content"/>
    <TextView
        android:textColor="@android:color/white"
        android:gravity="center_horizontal"
        android:id="@+id/tv_commit"
        android:background="@drawable/background_btn_colorprimary"
        android:padding="8dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        android:text="提交"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/edt_contact"
        app:layout_constraintStart_toStartOf="@+id/edt_contact"/>
    <FrameLayout
        android:layout_gravity="center"
        android:id="@+id/progress_container"
        android:background="@drawable/background_progress_bar"
        android:visibility="gone"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:elevation="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ProgressBar
            android:layout_gravity="center"
            android:id="@+id/progressView"
            android:layout_width="40dp"
            android:layout_height="40dp"/>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
