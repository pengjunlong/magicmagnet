<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/activity_about"
    android:background="@color/container_background"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="8dp">
            <RelativeLayout
                android:background="@color/blue"
                android:padding="0dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ProgressBar
                    android:theme="@style/AppTheme.WhiteAccent"
                    android:id="@+id/progressBar"
                    android:visibility="invisible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="0dp"
                    android:layout_alignParentRight="true"
                    style="?android:attr/progressBarStyleSmall"/>
                <TextView
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:id="@+id/tvTitleStatus"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="0dp"
                    android:text=""/>
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/tvTitleStatus">
                    <LinearLayout
                        android:gravity="center"
                        android:id="@+id/layout_vip"
                        android:background="@color/colorAccent"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_vip"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="4dp"/>
                        <TextView
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@android:color/white"
                            android:gravity="center"
                            android:id="@+id/tv_tip"
                            android:background="@color/colorAccent"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:layout_marginTop="0dp"
                            android:text="专业版用户·专享特权"/>
                    </LinearLayout>
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:id="@+id/layout_pay_no"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp">
                        <TextView
                            android:textStyle="bold"
                            android:textColor="@android:color/white"
                            android:id="@+id/tvTitleNo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="订单号"/>
                        <TextView
                            android:textColor="@android:color/white"
                            android:ellipsize="end"
                            android:id="@+id/tvNo"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:maxLines="2"
                            android:layout_weight="1"
                            android:inputType="numberPassword"/>
                        <TextView
                            android:textColor="@android:color/white"
                            android:id="@+id/tvNoState"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="8dp"/>
                        <TextView
                            android:textSize="12sp"
                            android:textColor="@color/tiny_white"
                            android:id="@+id/refresh_no"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:text="刷新"/>
                        <TextView
                            android:textColor="@android:color/white"
                            android:id="@+id/tv_copy_order"
                            android:background="?android:attr/selectableItemBackground"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="8dp"
                            android:text="@string/copy"/>
                    </LinearLayout>
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:id="@+id/layout_mcode"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp">
                        <TextView
                            android:textStyle="bold"
                            android:textColor="@android:color/white"
                            android:id="@+id/tvTitleMCode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="M码"/>
                        <TextView
                            android:textColor="@android:color/white"
                            android:ellipsize="end"
                            android:id="@+id/tvMcode"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="8dp"
                            android:maxWidth="150dp"
                            android:maxLines="2"
                            android:layout_weight="1"
                            android:inputType="numberPassword"/>
                        <TextView
                            android:textColor="@android:color/white"
                            android:id="@+id/tvMCodeState"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="8dp"/>
                        <TextView
                            android:textColor="@android:color/white"
                            android:id="@+id/tv_copy_mcode"
                            android:background="?android:attr/selectableItemBackground"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="8dp"
                            android:text="@string/copy"/>
                    </LinearLayout>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp">
                        <TextView
                            android:textStyle="bold"
                            android:textColor="@android:color/white"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="设备识别号"/>
                        <TextView
                            android:textColor="@android:color/white"
                            android:id="@+id/tvDeviceId"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="8dp"
                            android:layout_weight="1"/>
                        <TextView
                            android:textColor="@android:color/white"
                            android:id="@+id/tv_copy_device_id"
                            android:background="?android:attr/selectableItemBackground"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="8dp"
                            android:text="@string/copy"/>
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>
        </androidx.cardview.widget.CardView>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:showDividers="end|beginning"
            android:dividerPadding="2dp">
            <Button
                android:textStyle="bold"
                android:textColor="@color/default_font"
                android:gravity="center"
                android:id="@+id/btnCheckPay"
                android:background="@color/cardview_background"
                android:paddingLeft="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:text="激活专业版"/>
            <Button
                android:textStyle="bold"
                android:textColor="@color/default_font"
                android:gravity="center"
                android:id="@+id/btn_reactive"
                android:background="@color/cardview_background"
                android:paddingLeft="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:text="重新激活"/>
            <Button
                android:textStyle="bold"
                android:textColor="@color/default_font"
                android:gravity="center"
                android:id="@+id/btnFindMcode"
                android:background="@color/cardview_background"
                android:paddingLeft="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:text="自助恢复专业版"/>
            <Button
                android:textStyle="bold"
                android:textColor="@color/default_font"
                android:gravity="center"
                android:id="@+id/btnHelp"
                android:background="@color/cardview_background"
                android:paddingLeft="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:text="联系客服"/>
            <Button
                android:textStyle="bold"
                android:textColor="@color/tiny_red"
                android:gravity="center"
                android:id="@+id/btnBuy"
                android:background="@color/cardview_background"
                android:paddingLeft="8dp"
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:text="获取专业版"/>
        </LinearLayout>
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <TextView
            android:textColor="@color/colorAccent"
            android:gravity="center_horizontal"
            android:layout_gravity="center_horizontal"
            android:id="@+id/tvDetail"
            android:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:text="专业版特权详情\10常见问题"
            android:lineHeight="22sp"/>
    </LinearLayout>
</LinearLayout>
