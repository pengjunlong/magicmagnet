<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_container"
    android:background="@color/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/layoutAppbar"
            android:fitsSystemWindows="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:fitsSystemWindows="true"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_collapseMode="pin"
                app:popupTheme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
                app:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
                app:title="投屏"
                app:titleTextColor="@android:color/white"/>
        </com.google.android.material.appbar.AppBarLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:padding="24dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <include
                    android:layout_gravity="center_horizontal"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:layout_margin="8dp"
                    layout="@layout/layout_single_word_icon"/>
                <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:gravity="center_horizontal"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/tv_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="4dp"
                    android:maxLines="3"
                    app:autoSizeMaxTextSize="22sp"
                    app:autoSizeMinTextSize="14sp"
                    app:autoSizeTextType="uniform"/>
                <FrameLayout
                    android:id="@+id/ad_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <LinearLayout
                    android:gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/default_font"
                        android:id="@+id/tv_current"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="8dp"
                        android:layout_marginRight="4dp"
                        android:text="00:00"/>
                    <TextView
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/default_font"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="4dp"
                        android:layout_marginRight="4dp"
                        android:text="/"/>
                    <TextView
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/tiny_gray"
                        android:id="@+id/tv_total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="4dp"
                        android:layout_marginRight="16dp"
                        android:text="00:00"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:visibility="visible"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="32dp">
                    <SeekBar
                        android:id="@+id/seekbar_progress"
                        android:background="@null"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:maxHeight="4dp"
                        android:max="100"
                        android:progressDrawable="@drawable/progress_video"
                        android:minHeight="4dp"
                        android:thumb="@drawable/thumb_dlna_seek"
                        android:layout_weight="1"/>
                </LinearLayout>
                <LinearLayout
                    android:orientation="horizontal"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageButton
                        android:id="@+id/btn_volume_down"
                        android:background="?android:attr/selectableItemBackground"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_volume_down"
                        android:layout_weight="1"/>
                    <ImageButton
                        android:id="@+id/btn_volume_up"
                        android:background="?android:attr/selectableItemBackground"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_volume_up"
                        android:layout_weight="1"/>
                    <ImageButton
                        android:id="@+id/btn_rewind"
                        android:background="?android:attr/selectableItemBackground"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_rewind"
                        android:layout_weight="1"/>
                    <ImageButton
                        android:id="@+id/btn_play"
                        android:background="?android:attr/selectableItemBackground"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_play_dark"
                        android:layout_weight="1"/>
                    <ImageButton
                        android:id="@+id/btn_forward"
                        android:background="?android:attr/selectableItemBackground"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_foward"
                        android:layout_weight="1"/>
                    <ImageButton
                        android:id="@+id/btn_stop"
                        android:background="?android:attr/selectableItemBackground"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_stop"
                        android:layout_weight="1"/>
                </LinearLayout>
                <LinearLayout
                    android:orientation="horizontal"
                    android:paddingLeft="32dp"
                    android:paddingRight="32dp"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">
                    <ImageButton
                        android:id="@+id/btn_close"
                        android:background="@color/transparent"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_close"
                        android:layout_weight="1"/>
                    <ImageButton
                        android:id="@+id/btn_mute"
                        android:background="@color/transparent"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_mute"
                        android:layout_weight="1"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
