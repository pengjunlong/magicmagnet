<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:background="?android:attr/selectableItemBackground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/layout_movie_main"
            android:paddingLeft="0dp"
            android:paddingTop="0dp"
            android:paddingRight="4dp"
            android:paddingBottom="0dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/iv_pic"
                android:layout_width="150dp"
                android:layout_height="250dp"
                android:layout_marginRight="8dp"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"
                android:layout_marginEnd="8dp"/>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <androidx.appcompat.widget.AppCompatTextView
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/title"
                        android:ellipsize="end"
                        android:id="@+id/tv_movie_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:maxLines="2"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif"
                        android:layout_marginStart="8dp"
                        app:autoSizeMaxTextSize="28sp"
                        app:autoSizeMinTextSize="20sp"
                        app:autoSizeTextType="uniform"/>
                    <ImageView
                        android:id="@+id/iv_star_movie"
                        android:background="?android:attr/selectableItemBackground"
                        android:paddingBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        app:srcCompat="@drawable/ic_star_search_movie"/>
                </LinearLayout>
                <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="18sp"
                    android:textColor="@color/subtitle"
                    android:ellipsize="end"
                    android:id="@+id/tv_movie_detail"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_margin="8dp"
                    android:maxLines="6"
                    android:layout_weight="1"
                    app:autoSizeMaxTextSize="18sp"
                    app:autoSizeMinTextSize="8sp"
                    app:autoSizeTextType="none"/>
                <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="14sp"
                    android:textColor="@color/subtitle"
                    android:ellipsize="end"
                    android:gravity="end"
                    android:layout_gravity="end"
                    android:id="@+id/tv_movie_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:maxLines="1"
                    app:autoSizeMaxTextSize="14sp"
                    app:autoSizeMinTextSize="6sp"
                    app:autoSizeTextType="uniform"/>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</androidx.cardview.widget.CardView>
