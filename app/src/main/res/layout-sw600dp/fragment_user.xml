<?xml version="1.0" encoding="utf-8"?>
<com.flipboard.bottomsheet.BottomSheetLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_bottom_sheet"
    android:background="@color/container_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.core.widget.NestedScrollView
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <FrameLayout
                android:layout_gravity="center"
                android:id="@+id/progress_container"
                android:background="@drawable/background_progress_bar"
                android:visibility="gone"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:elevation="8dp"
                app:layout_constraintBottom_toBottomOf="@+id/layout_cloud_sync"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <ProgressBar
                    android:layout_gravity="center"
                    android:id="@+id/progressView"
                    android:visibility="visible"
                    android:layout_width="40dp"
                    android:layout_height="40dp"/>
            </FrameLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/layout_pro"
                android:background="@drawable/bg_white_stroke"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:layout_constraintEnd_toStartOf="@+id/layout_cloud_sync"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="@+id/layout_user_info"
                app:layout_constraintTop_toBottomOf="@+id/layout_announcement">
                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginTop="16dp"
                    android:src="@drawable/pro"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"/>
                <TextView
                    android:textColor="@color/default_font"
                    android:layout_gravity="center_horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp"
                    android:text="专业版"
                    android:fontFamily="@font/fz"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/layout_cloud_sync"
                android:background="@drawable/bg_white_stroke"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginStart="16dp"
                app:layout_constraintEnd_toStartOf="@+id/layout_question"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toEndOf="@+id/layout_pro"
                app:layout_constraintTop_toBottomOf="@+id/layout_announcement"
                app:layout_goneMarginStart="0dp">
                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginTop="16dp"
                    android:src="@drawable/cloud_sync"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"/>
                <TextView
                    android:textColor="@color/default_font"
                    android:layout_gravity="center_horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp"
                    android:text="云同步"
                    android:fontFamily="@font/fz"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/layout_question"
                android:background="@drawable/bg_white_stroke"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                app:layout_constraintBottom_toBottomOf="@+id/layout_cloud_sync"
                app:layout_constraintStart_toEndOf="@+id/layout_cloud_sync"
                app:layout_constraintTop_toTopOf="@+id/layout_cloud_sync">
                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginTop="16dp"
                    android:src="@drawable/question"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"/>
                <TextView
                    android:textColor="@color/default_font"
                    android:layout_gravity="center_horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp"
                    android:text="常见问题"
                    android:fontFamily="@font/fz"/>
            </LinearLayout>
            <TextView
                android:textSize="20sp"
                android:textColor="@color/font_like_gray"
                android:id="@+id/tv_history_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="历史"
                android:fontFamily="@font/fz_bold"
                app:layout_constraintStart_toStartOf="@+id/layout_user_info"
                app:layout_constraintTop_toBottomOf="@+id/rv_bookmark"/>
            <TextView
                android:textStyle="bold"
                android:textColor="@color/tiny_gray"
                android:id="@+id/tv_more_history"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:text="更多"
                app:layout_constraintBottom_toBottomOf="@+id/tv_history_label"
                app:layout_constraintEnd_toEndOf="@+id/layout_user_info"
                app:layout_constraintTop_toTopOf="@+id/tv_history_label"/>
            <TextView
                android:textStyle="bold"
                android:textColor="@color/tiny_gray"
                android:id="@+id/tv_more_bookmark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:text="更多"
                app:layout_constraintBottom_toBottomOf="@+id/tv_bookmark_label"
                app:layout_constraintEnd_toEndOf="@+id/layout_user_info"
                app:layout_constraintTop_toTopOf="@+id/tv_bookmark_label"/>
            <TextView
                android:textStyle="bold"
                android:textColor="@color/tiny_gray"
                android:id="@+id/tv_more_film_review"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:text="更多"
                app:layout_constraintBottom_toBottomOf="@+id/tv_favorite_film_review_label"
                app:layout_constraintEnd_toEndOf="@+id/layout_user_info"
                app:layout_constraintTop_toTopOf="@+id/tv_favorite_film_review_label"/>
            <TextView
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/font_like_gray"
                android:id="@+id/tv_bookmark_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="书签"
                app:layout_constraintStart_toStartOf="@+id/layout_user_info"
                app:layout_constraintTop_toBottomOf="@+id/rv_film_review"/>
            <TextView
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/font_like_gray"
                android:id="@+id/tv_favorite_film_review_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="影评"
                app:layout_constraintStart_toStartOf="@+id/layout_user_info"
                app:layout_constraintTop_toBottomOf="@+id/layout_cloud_sync"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_user_info"
                android:background="@drawable/bg_white_stroke"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_margin="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <ImageView
                    android:id="@+id/iv_option"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_video_card_option"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/layout_pro_sign"
                    android:background="@drawable/bg_yellow"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    app:layout_constraintStart_toStartOf="@+id/tvUserName"
                    app:layout_constraintTop_toBottomOf="@+id/tvUserName">
                    <ImageView
                        android:layout_gravity="center_vertical"
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:src="@drawable/ic_vip"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@color/white"
                        android:layout_gravity="center_vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="专业版"
                        android:fontFamily="@font/zona_pro_thin"
                        android:layout_marginStart="2dp"
                        android:layout_marginEnd="4dp"/>
                </LinearLayout>
                <TextView
                    android:textSize="16sp"
                    android:ellipsize="end"
                    android:id="@+id/tvUserName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:maxLines="1"
                    android:fontFamily="@font/fz_bold"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintEnd_toStartOf="@+id/iv_option"
                    app:layout_constraintStart_toEndOf="@+id/iv_avater"
                    app:layout_constraintTop_toTopOf="@+id/iv_avater"/>
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_avater"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:src="@drawable/miao"
                    android:layout_marginStart="16dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <FrameLayout
                android:id="@+id/layout_announcement"
                android:background="@drawable/bg_white_stroke"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:layout_constraintEnd_toEndOf="@+id/layout_user_info"
                app:layout_constraintStart_toStartOf="@+id/layout_user_info"
                app:layout_constraintTop_toBottomOf="@+id/layout_user_info">
                <com.magicmagnet.common.view.AnnouncementTextView
                    android:layout_gravity="center"
                    android:id="@+id/tv_announcement"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    app:direction="top_to_bottom"
                    app:ellipsize="middle"
                    app:textColor="@color/default_font"
                    app:text_gravity="center"/>
            </FrameLayout>
            <androidx.constraintlayout.widget.Group
                android:id="@+id/group_history"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:constraint_referenced_ids="tv_more_history,rv_history,tv_history_label"/>
            <androidx.constraintlayout.widget.Group
                android:id="@+id/group_bookmark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:constraint_referenced_ids="tv_more_bookmark,rv_bookmark,tv_bookmark_label"/>
            <androidx.constraintlayout.widget.Group
                android:id="@+id/group_film_review"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:constraint_referenced_ids="tv_more_film_review,rv_film_review,tv_favorite_film_review_label"/>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_history"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@+id/layout_user_info"
                app:layout_constraintStart_toStartOf="@+id/layout_user_info"
                app:layout_constraintTop_toBottomOf="@+id/tv_history_label"/>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_bookmark"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                app:layout_constraintEnd_toEndOf="@+id/layout_user_info"
                app:layout_constraintStart_toStartOf="@+id/layout_user_info"
                app:layout_constraintTop_toBottomOf="@+id/tv_bookmark_label"/>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_film_review"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                app:layout_constraintEnd_toEndOf="@+id/layout_user_info"
                app:layout_constraintStart_toStartOf="@+id/layout_user_info"
                app:layout_constraintTop_toBottomOf="@+id/tv_favorite_film_review_label"/>
            <androidx.constraintlayout.widget.Group
                android:id="@+id/group_3_btn"
                android:visibility="visible"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:constraint_referenced_ids="layout_pro,layout_cloud_sync,layout_question"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</com.flipboard.bottomsheet.BottomSheetLayout>
