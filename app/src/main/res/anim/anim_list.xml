<?xml version="1.0" encoding="utf-8"?>
<set xmlns:android="http://schemas.android.com/apk/res/android">
    <scale
        android:duration="600"
        android:pivotX="50%"
        android:pivotY="70%"
        android:fromXScale="0.9"
        android:toXScale="1"
        android:fromYScale="0.9"
        android:toYScale="1"/>
    <alpha
        android:duration="600"
        android:fromAlpha="0.5"
        android:toAlpha="1"/>
    <translate
        android:duration="600"
        android:fromYDelta="20%"
        android:toYDelta="1"/>
</set>
