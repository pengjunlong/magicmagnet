<?xml version="1.0" encoding="utf-8"?>
<com.arlib.floatingsearchview.FloatingSearchView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/searchView"
    android:fitsSystemWindows="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:floatingSearch_actionMenuOverflowColor="@color/samsung_dark"
    app:floatingSearch_backgroundColor="@color/samsung_dark"
    app:floatingSearch_clearBtnColor="@color/tiny_white"
    app:floatingSearch_dividerColor="@color/dark_gray"
    app:floatingSearch_hintTextColor="@color/tiny_white"
    app:floatingSearch_leftActionColor="@color/tiny_white"
    app:floatingSearch_leftActionMode="showHamburger"
    app:floatingSearch_menuItemIconColor="@color/tiny_white"
    app:floatingSearch_searchBarMarginLeft="8dp"
    app:floatingSearch_searchBarMarginRight="8dp"
    app:floatingSearch_searchBarMarginTop="4dp"
    app:floatingSearch_searchHint="@string/hint_search"
    app:floatingSearch_showSearchKey="true"
    app:floatingSearch_viewSearchInputTextColor="@color/tiny_white"
    app:floatingSearch_viewSuggestionItemTextColor="@color/tiny_white"
    app:floatingSearch_viewTextColor="@color/tiny_white"/>
